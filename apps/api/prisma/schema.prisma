generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  dayTemplate  DayTemplate?
}

model DayTemplate {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id])
  wakeTime  String
  sleepTime String
  blocks    Block[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Block {
  id            String       @id @default(cuid())
  dayTemplateId String
  dayTemplate   DayTemplate  @relation(fields: [dayTemplateId], references: [id])
  type          BlockType
  name          String
  startTime     String
  endTime       String
  energyLevel   EnergyLevel?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
	@@map("DayTemplateBlock")
}

enum BlockType {
  CONTAINER
  ANCHOR
  NO_TASK
}

enum EnergyLevel {
  HIGH
  MEDIUM
  LOW
}

model AppConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

